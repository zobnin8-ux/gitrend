{
  "name": "github-trends-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Локальный дашборд для отслеживания популярных и быстрорастущих GitHub-репозиториев",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "start:prod": "npm run build && npm run start",
    "rebuild:native": "npm rebuild better-sqlite3"
  },
  "engines": {
    "node": ">=20 <=22"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3"
  }
}
