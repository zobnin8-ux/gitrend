# GitHub Personal Access Token (обязателен для обновления данных).
# Создать: https://github.com/settings/tokens  (достаточно прав public_repo / read-only)
GITHUB_TOKEN=

# OpenAI API ключ (НЕОБЯЗАТЕЛЕН).
# Если указан — для репозиториев генерируются краткие описания на русском.
# Если пуст — приложение работает без AI-функций.
OPENAI_API_KEY=

# Путь к git.exe (необязательно). Нужен для кнопки «Опубликовать на GitHub», если Git не в PATH.
# GIT_EXECUTABLE=C:\Program Files\Git\cmd\git.exe

# Обход ошибки SSL при git push на Windows (необязательно).
# GIT_SSL_NO_VERIFY=true
